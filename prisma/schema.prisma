generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  EDITOR
  VIEWER
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
  REFUND
  ADJUSTMENT
}

enum AccountType {
  CASH
  BANK_ACCOUNT
  CREDIT_CARD
  DIGITAL_WALLET
  INVESTMENT
  OTHER
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum NotificationType {
  BUDGET_ALERT
  BILL_REMINDER
  UNUSUAL_SPENDING
  SYSTEM
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TransactionStatus {
  PENDING
  CLEARED
  RECONCILED
  VOID
}

// ─── USER & AUTH ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  workspaceMembers WorkspaceMember[]
  auditLogs        AuditLog[]
  notifications    Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── WORKSPACE ───────────────────────────────────────────────────────────────

model Workspace {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  currency   String   @default("BRL")
  timezone   String   @default("America/Sao_Paulo")
  locale     String   @default("pt-BR")
  dateFormat String   @default("DD/MM/YYYY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members               WorkspaceMember[]
  financialAccounts     FinancialAccount[]
  categories            Category[]
  tags                  Tag[]
  merchants             Merchant[]
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  importJobs            ImportJob[]
  exchangeRates         ExchangeRate[]
  auditLogs             AuditLog[]
  costCenters           CostCenter[]
  templates             TransactionTemplate[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        UserRole @default(VIEWER)
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ─── FINANCIAL ACCOUNTS ──────────────────────────────────────────────────────

model FinancialAccount {
  id             String      @id @default(cuid())
  workspaceId    String
  name           String
  type           AccountType @default(BANK_ACCOUNT)
  currency       String      @default("BRL")
  initialBalance Decimal     @default(0) @db.Decimal(18, 2)
  currentBalance Decimal     @default(0) @db.Decimal(18, 2)
  color          String?
  icon           String?
  isActive       Boolean     @default(true)
  isDefault      Boolean     @default(false)
  institution    String?
  lastFour       String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation("AccountTransactions")
  transfersTo  Transaction[] @relation("TransferToAccount")

  @@map("financial_accounts")
}

// ─── CATEGORIES ──────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#6366f1")
  icon        String   @default("tag")
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent       Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]        @relation("CategoryHierarchy")
  transactions Transaction[]
  splits       TransactionSplit[]
  budgets      Budget[]

  @@unique([workspaceId, name, parentId])
  @@map("categories")
}

// ─── TAGS ────────────────────────────────────────────────────────────────────

model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())

  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]

  @@unique([workspaceId, name])
  @@map("tags")
}

// ─── MERCHANTS ───────────────────────────────────────────────────────────────

model Merchant {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  category    String?
  logo        String?
  website     String?
  isActive    Boolean  @default(true)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([workspaceId, name])
  @@map("merchants")
}

// ─── COST CENTERS ────────────────────────────────────────────────────────────

model CostCenter {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  code        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([workspaceId, name])
  @@map("cost_centers")
}

// ─── TRANSACTIONS ────────────────────────────────────────────────────────────

model Transaction {
  id           String            @id @default(cuid())
  workspaceId  String
  accountId    String
  transferToId String?
  categoryId   String?
  merchantId   String?
  costCenterId String?
  type         TransactionType   @default(EXPENSE)
  status       TransactionStatus @default(CLEARED)
  amount       Decimal           @db.Decimal(18, 2)
  currency     String            @default("BRL")
  exchangeRate Decimal?          @db.Decimal(18, 6)
  description  String?
  notes        String?
  date         DateTime
  paymentMethod String?
  reference    String?
  isRecurring  Boolean           @default(false)
  recurringId  String?
  isSplit      Boolean           @default(false)
  isDraft      Boolean           @default(false)
  isArchived   Boolean           @default(false)
  createdById  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account    FinancialAccount  @relation("AccountTransactions", fields: [accountId], references: [id])
  transferTo FinancialAccount? @relation("TransferToAccount", fields: [transferToId], references: [id])
  category   Category?         @relation(fields: [categoryId], references: [id])
  merchant   Merchant?         @relation(fields: [merchantId], references: [id])
  costCenter CostCenter?       @relation(fields: [costCenterId], references: [id])
  recurring  RecurringTransaction? @relation(fields: [recurringId], references: [id])
  splits     TransactionSplit[]
  tags       TransactionTag[]
  attachments Attachment[]

  @@index([workspaceId, date])
  @@index([workspaceId, accountId])
  @@index([workspaceId, categoryId])
  @@map("transactions")
}

model TransactionSplit {
  id            String   @id @default(cuid())
  transactionId String
  categoryId    String?
  amount        Decimal  @db.Decimal(18, 2)
  description   String?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id])

  @@map("transaction_splits")
}

model TransactionTag {
  transactionId String
  tagId         String

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

// ─── ATTACHMENTS ─────────────────────────────────────────────────────────────

model Attachment {
  id            String   @id @default(cuid())
  transactionId String
  fileName      String
  fileType      String
  fileSize      Int
  url           String
  ocrData       Json?
  ocrProcessed  Boolean  @default(false)
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─── RECURRING TRANSACTIONS ──────────────────────────────────────────────────

model RecurringTransaction {
  id            String              @id @default(cuid())
  workspaceId   String
  name          String
  frequency     RecurrenceFrequency @default(MONTHLY)
  interval      Int                 @default(1)
  startDate     DateTime
  endDate       DateTime?
  nextDueDate   DateTime
  lastProcessed DateTime?
  isActive      Boolean             @default(true)
  templateData  Json
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("recurring_transactions")
}

// ─── TEMPLATES ───────────────────────────────────────────────────────────────

model TransactionTemplate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  data        Json
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("transaction_templates")
}

// ─── BUDGETS ─────────────────────────────────────────────────────────────────

model Budget {
  id          String    @id @default(cuid())
  workspaceId String
  categoryId  String?
  name        String
  amount      Decimal   @db.Decimal(18, 2)
  period      String    @default("MONTHLY")
  startDate   DateTime
  endDate     DateTime?
  alertAt     Decimal   @default(80) @db.Decimal(5, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])

  @@map("budgets")
}

// ─── EXCHANGE RATES ──────────────────────────────────────────────────────────

model ExchangeRate {
  id           String   @id @default(cuid())
  workspaceId  String
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(18, 6)
  date         DateTime
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fromCurrency, toCurrency, date])
  @@map("exchange_rates")
}

// ─── IMPORT JOBS ─────────────────────────────────────────────────────────────

model ImportJob {
  id            String       @id @default(cuid())
  workspaceId   String
  fileName      String
  fileType      String
  status        ImportStatus @default(PENDING)
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  errorRows     Int          @default(0)
  mapping       Json?
  preview       Json?
  errors        Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("import_jobs")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  action      String
  resource    String
  resourceId  String?
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}
